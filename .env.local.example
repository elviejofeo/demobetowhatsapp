# --- Variables de entorno para Vercel ---
# NO subir el archivo real .env.local a GitHub (ya está en .gitignore)

# Tu API key de Anthropic (va SOLO en Vercel, nunca en el código)
ANTHROPIC_API_KEY=sk-ant-...

# Fecha/hora de expiración del demo (formato ISO).
# Después de esta fecha, Beto deja de responder y muestra "demo finalizado".
# Ejemplo: expira el 30 de junio de 2026 a las 18:00 hora de Monterrey (UTC-6 = 00:00 UTC del 1 jul)
DEMO_EXPIRES_AT=2026-06-30T18:00:00-06:00
